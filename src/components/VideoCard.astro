---
/**
 * Card video YouTube — dùng THUMBNAIL + link, KHÔNG iframe
 * (quy ước Project X từ vivi-soul: iframe dễ dính Error 153, chậm, kèm cookie).
 * id rỗng → card "sắp ra mắt" (không render ảnh hỏng).
 */
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
const watchUrl = `https://www.youtube.com/watch?v=${id}`;
const thumbUrl = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

{
  id ? (
    <a class="card video-card" href={watchUrl} target="_blank" rel="noopener noreferrer">
      <span class="video-thumb">
        <img src={thumbUrl} alt="" width="480" height="360" loading="lazy" />
        <span class="video-play" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13l11-6.5z" /></svg>
        </span>
      </span>
      <span class="video-title">{title}</span>
    </a>
  ) : (
    <div class="card video-card video-card--soon">
      <span class="video-thumb video-thumb--soon" aria-hidden="true">
        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="6" y="14" width="28" height="22" rx="3" />
          <path d="M34 22l8-5v14l-8-5" />
        </svg>
        <span class="soon-badge">Sắp ra mắt</span>
      </span>
      <span class="video-title">{title}</span>
    </div>
  )
}

<style>
  .video-card {
    display: flex;
    flex-direction: column;
    color: var(--fg);
  }
  .video-thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }
  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.25s ease;
  }
  .video-card:hover .video-thumb img { opacity: 0.82; }
  .video-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .video-play svg {
    width: 54px;
    height: 54px;
    padding: 13px;
    box-sizing: border-box;
    border-radius: 50%;
    background: rgba(5, 7, 13, 0.72);
    border: 1.5px solid var(--gold);
    color: var(--gold);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .video-card:hover .video-play svg {
    background: var(--gold);
    color: #0a0a04;
  }
  .video-thumb--soon {
    display: grid;
    place-items: center;
    color: var(--muted-soft);
  }
  .video-thumb--soon svg { width: 52px; height: 52px; }
  .soon-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold-deep);
    background: rgba(5, 7, 13, 0.7);
  }
  .video-title {
    padding: 16px 18px 18px;
    font-size: 14.5px;
    font-weight: 500;
    line-height: 1.45;
  }
  .video-card--soon { opacity: 0.75; }
</style>
