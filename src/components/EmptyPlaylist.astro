---
import { SITE } from '../config/site';

interface Props {
  topicTitle: string;
}
const { topicTitle } = Astro.props;
---

<div class="empty-playlist" data-reveal>
  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="5" y="10" width="38" height="28" rx="4" />
    <path d="M5 18h38" />
    <path d="M20 25.5l8 4.5-8 4.5z" />
    <circle cx="10.5" cy="14" r="1.2" fill="currentColor" />
    <circle cx="15.5" cy="14" r="1.2" fill="currentColor" />
  </svg>
  <h3>Playlist “{topicTitle}” đang được dựng</h3>
  <p>
    Video đầu tiên của chủ đề này sắp lên sóng. Đăng ký kênh để nhận thông báo —
    trong lúc chờ, các bài viết bên dưới đã sẵn sàng.
  </p>
  <a class="btn btn--ghost btn--sm" href={SITE.channelUrl} target="_blank" rel="noopener noreferrer">
    Đăng ký {SITE.channelHandle}
  </a>
</div>

<style>
  .empty-playlist {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    padding: 48px 28px;
    border: 1.5px dashed var(--border-strong);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--surface) 60%, transparent);
  }
  svg {
    width: 56px;
    height: 56px;
    color: var(--gold);
    opacity: 0.85;
    margin-bottom: 6px;
  }
  h3 { font-size: 21px; margin: 0; }
  p {
    margin: 0 0 14px;
    color: var(--muted);
    font-size: 14.5px;
    max-width: 52ch;
  }
</style>
