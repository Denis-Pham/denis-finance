---
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';

const topics = (await getCollection('topics')).sort((a, b) => a.data.order - b.data.order);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">{SITE.shortName}</span>
        <span>{SITE.name}</span>
      </a>
      <p>{SITE.tagline}. Blog đồng hành cùng kênh YouTube — mỗi chủ đề là một playlist.</p>
      <a class="btn btn--ghost btn--sm" href={SITE.channelUrl} target="_blank" rel="noopener noreferrer">
        YouTube {SITE.channelHandle}
      </a>
    </div>

    <nav aria-label="Chủ đề">
      <h3>Chủ đề</h3>
      <ul>
        {topics.map((t) => (
          <li><a href={`/chu-de/${t.id}/`}>{t.data.title}</a></li>
        ))}
      </ul>
    </nav>

    <nav aria-label="Khám phá">
      <h3>Khám phá</h3>
      <ul>
        <li><a href="/bai-viet/">Tất cả bài viết</a></li>
        <li><a href="/chu-de/">Tất cả chủ đề</a></li>
        <li><a href="/gioi-thieu/">Giới thiệu</a></li>
        <li><a href="/rss.xml">RSS feed</a></li>
      </ul>
    </nav>
  </div>

  <div class="wrap footer-bottom">
    <p>© {year} {SITE.name}. Nội dung mang tính giáo dục — không phải lời khuyên đầu tư.</p>
    <p class="footer-note">Website tĩnh tự host · không cookie, không tracker.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 40px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
    padding-block: 56px 40px;
  }
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--fg);
    font: 600 17px/1 var(--font-body);
    margin-bottom: 16px;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--gold);
    color: var(--gold);
    font: 700 14px/1 var(--font-display);
  }
  .footer-brand p {
    color: var(--muted-soft);
    font-size: 14.5px;
    max-width: 34ch;
    margin-bottom: 20px;
  }
  h3 {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin-bottom: 10px; }
  ul a { color: var(--muted); font-size: 14.5px; }
  ul a:hover { color: var(--gold); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-block: 20px 26px;
    border-top: 1px solid var(--border);
  }
  .footer-bottom p {
    margin: 0;
    color: var(--muted-soft);
    font-size: 13px;
  }

  @media (max-width: 820px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
