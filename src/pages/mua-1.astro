---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, withBase } from '../config/site';

/**
 * Trang tổng kết Mùa 1 — 13 tập "Ví Nhà Mình".
 * Video public → link YouTube; tập private hẹn giờ → hiện ngày lên sóng (theo quy ước
 * upcoming của site: không link vào video chưa công khai).
 * Cập nhật khi từng tập public: đổi live=true cho tập đó.
 */
const CH = SITE.channelUrl;

type Ep = { n: string; title: string; tool: string; date: string; id: string; live: boolean };
const episodes: Ep[] = [
  { n: '01', title: 'Vì sao kiếm nhiều vẫn thiếu?', tool: 'Quả bóng lối sống', date: 'Đang chiếu', id: 'lNTOrJg7pcw', live: true },
  { n: '02', title: 'Hệ ba xô: chia lương xài cả tháng', tool: 'Ba cái xô', date: 'Đang chiếu', id: 'Dff44SK5Y7s', live: true },
  { n: '03', title: 'Quỹ dự phòng: cái phao trước khi bơi', tool: 'Phao cứu sinh', date: '20:00 · 22/7', id: 'F7D5e-4sg0M', live: false },
  { n: '04', title: 'Gỡ nợ đúng thứ tự', tool: 'Gỡ neo nợ', date: '20:00 · 26/7', id: 'zxqrecxw-L0', live: false },
  { n: '05', title: 'Lãi kép: bắt đầu sớm thắng bắt đầu to', tool: 'Hạt mầm', date: '20:00 · 30/7', id: 'syPlRuNC-EA', live: false },
  { n: '06', title: 'Rủi ro & lợi nhuận: cái giá của từng chỗ', tool: 'Cân hai đĩa', date: '20:00 · 2/8', id: 'HwX1yihRoPE', live: false },
  { n: '07', title: 'Đa dạng hóa: chia giỏ trứng cho đúng', tool: 'Vườn ba tầng', date: '20:00 · 5/8', id: 'QZzI29LaHvE', live: false },
  { n: '08', title: 'Tăng thu nhập: máy bơm của khu vườn', tool: 'Máy bơm', date: '20:00 · 8/8', id: 'qkE8aOOYiDI', live: false },
  { n: '09', title: 'Tiền chung của hai người: gộp, góp hay chia?', tool: 'Ví lồng tim', date: '20:00 · 11/8', id: 'rIiP4_DW2jo', live: false },
  { n: '10', title: 'Dạy con hiểu tiền: việc thật, tiền thật', tool: 'Hũ ba ngăn', date: '20:00 · 14/8', id: '01gymUu4tkI', live: false },
  { n: '11', title: 'Tiền với cha mẹ già: biếu bao nhiêu là đủ?', tool: 'Lu nước & hũ gốm', date: '20:00 · 17/8', id: '_0Ii5H-_uXw', live: false },
  { n: '12', title: 'Bảo hiểm: mua cái khiên, đừng mua cái mền', tool: 'Khiên gỗ', date: '20:00 · 20/8', id: 'EUMf-hV3gW8', live: false },
  { n: '13', title: 'Ráp cả hệ: một tháng của ví nhà mình', tool: 'Bản đồ cả hệ', date: '20:00 · 23/8', id: 'RbpgJt1aZDg', live: false },
];

const watch = (id: string) => `https://www.youtube.com/watch?v=${id}`;

const principles = [
  { n: '01', title: 'Thấy rõ trước khi sửa', text: 'Bật đèn lên trước đã — minh bạch với chính mình, và minh bạch trong nhà. Cái gì không thấy thì không sửa được.' },
  { n: '02', title: 'Trả mình trước', text: 'Tương lai và cái phao được chia ngay khi tiền vừa vào, trước khi nó kịp bốc hơi qua trăm thứ lặt vặt.' },
  { n: '03', title: 'Mỗi đồng một việc', text: 'Đồng tiền nào không được giao việc là đồng tiền đi lạc. Tiền có tên thì tiền ở lại.' },
  { n: '04', title: 'Tiền là công cụ, không phải điểm số', text: 'Đích cuối là cả nhà nói được với nhau về tiền — không sợ, không giấu, không xấu hổ.' },
];
---

<BaseLayout
  title="Mùa 1 · Ráp cả ví nhà mình"
  description="Toàn cảnh Mùa 1 của Ví Nhà Mình — 13 tập, từ cái xô chia lương đầu tiên tới tấm bản đồ tài chính hoàn chỉnh của cả gia đình ba thế hệ."
>
  <section class="section page-hero">
    <div class="wrap" data-reveal>
      <p class="eyebrow">Mùa 1 · Tập cuối 23/8</p>
      <h1>Ráp cả ví nhà mình</h1>
      <p class="lead">
        Mười ba tập, mỗi tuần một món đồ nghề — bắt đầu từ câu hỏi <em>“vì sao kiếm hoài vẫn thiếu”</em>,
        đi qua cái phao, hạt mầm, khu vườn, tới cái khiên, rồi ráp tất cả thành một hệ chạy được
        cho một gia đình bình thường. Đây là bản đồ của cả mùa.
      </p>
      <div class="season-stats">
        <div><strong>13</strong><span>tập trọn mùa</span></div>
        <div><strong>3 ngày</strong><span>một tập, đều đặn</span></div>
        <div><strong>3 thế hệ</strong><span>vợ chồng · con · cha mẹ</span></div>
      </div>
      <a class="btn" href={CH} target="_blank" rel="noopener noreferrer">Xem trên {SITE.channelHandle}</a>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="wrap">
      <div class="grid grid--2 arc-grid">
        <div class="card arc" data-reveal>
          <h2>Mạch dựng hệ</h2>
          <p>
            Tập 1 tới 8 dựng dần một sơ đồ nước: <strong>máy bơm</strong> thu nhập đẩy nước vào,
            chia <strong>ba cái xô</strong>, gỡ <strong>neo nợ</strong> cho khỏi rò, rồi <strong>phao</strong>
            và <strong>khiên</strong> chắn hai lớp, cuối cùng gieo <strong>mầm</strong> thành <strong>khu vườn</strong>
            có <strong>cân rủi ro</strong> canh. Tập 13 ráp tất cả thành một tấm bản đồ.
          </p>
        </div>
        <div class="card arc" data-reveal>
          <h2>Mạch ba thế hệ</h2>
          <p>
            Tập 9 tới 11 mở rộng cái ví ra cả nhà: <strong>ví chung của hai vợ chồng</strong>,
            <strong>hũ ba ngăn của con</strong>, rồi <strong>lu nước của cha mẹ già</strong> —
            khép lại đúng nghĩa cái tên “Ví Nhà Mình”. Mỗi tập nối tiếp tập trước, xem liền mạch không hụt.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tint">
    <div class="wrap">
      <p class="eyebrow" data-reveal>Trọn 13 tập</p>
      <h2 class="timeline-head" data-reveal>Cả mùa, theo thứ tự</h2>
      <ol class="timeline">
        {
          episodes.map((e) => (
            <li class="ep" data-reveal>
              <span class="ep-n">{e.n}</span>
              <div class="ep-body">
                <h3 class="ep-title">{e.title}</h3>
                <span class="ep-tool">{e.tool}</span>
              </div>
              <div class="ep-meta">
                {e.live ? (
                  <a class="ep-watch" href={watch(e.id)} target="_blank" rel="noopener noreferrer">
                    Đang chiếu →
                  </a>
                ) : (
                  <span class="ep-date">{e.date}</span>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>Rút cả mùa thành bốn câu</p>
      <h2 class="timeline-head" data-reveal>Bốn nguyên tắc gốc</h2>
      <div class="grid grid--2 principle-grid">
        {
          principles.map((p) => (
            <div class="card principle" data-reveal>
              <span class="principle-n">{p.n}</span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cta-final card" data-reveal>
        <div>
          <p class="eyebrow">Mùa 1 đã trọn</p>
          <h2>Ví nhà mình chưa bao giờ là chuyện con số.</h2>
          <p class="lead">
            Nó là chuyện cả nhà cùng thấy, cùng nói được về tiền, và cùng đứng vững đủ lâu để lo cho nhau.
            Mùa sau sẽ quay lại theo điều bạn cần — để lại một dòng trong phần bình luận nhé.
          </p>
        </div>
        <div class="cta-actions">
          <a class="btn" href={CH} target="_blank" rel="noopener noreferrer">Đăng ký {SITE.channelHandle}</a>
          <a class="btn btn--ghost" href={withBase('/chu-de/')}>Xem theo chủ đề</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero h1 {
    font-size: clamp(34px, 5.4vw, 58px);
    margin: 16px 0 14px;
  }
  .page-hero { padding-bottom: 40px; }
  .page-hero .lead { max-width: 60ch; }

  .season-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    margin: 30px 0 28px;
  }
  .season-stats div { display: flex; flex-direction: column; gap: 2px; }
  .season-stats strong {
    font: 700 30px/1 var(--font-display);
    color: var(--gold);
  }
  .season-stats span { color: var(--muted); font-size: 13.5px; }

  .arc-grid { gap: 28px; }
  .arc { padding: 30px 28px; }
  .arc h2 { font-size: 22px; margin: 0 0 12px; }
  .arc p { color: var(--muted); font-size: 15px; margin: 0; }
  .arc strong { color: var(--fg); font-weight: 600; }

  .timeline-head { font-size: clamp(24px, 3.4vw, 34px); margin: 10px 0 28px; }

  .timeline { list-style: none; margin: 0; padding: 0; }
  .ep {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 0;
    border-top: 1px solid var(--border);
  }
  .ep:last-child { border-bottom: 1px solid var(--border); }
  .ep-n {
    font: 700 16px/1 var(--font-display);
    color: var(--gold);
    letter-spacing: 0.04em;
    width: 34px;
    flex-shrink: 0;
  }
  .ep-body { flex: 1; min-width: 0; }
  .ep-title { font-size: 16.5px; font-weight: 600; margin: 0 0 3px; }
  .ep-tool { color: var(--muted); font-size: 13px; }
  .ep-meta { flex-shrink: 0; text-align: right; }
  .ep-date { color: var(--muted); font-size: 13.5px; font-variant-numeric: tabular-nums; }
  .ep-watch {
    color: var(--gold);
    font-size: 13.5px;
    font-weight: 600;
    white-space: nowrap;
  }
  .ep-watch:hover { text-decoration: underline; }

  .principle-grid { gap: 22px; }
  .principle { padding: 28px 26px 30px; }
  .principle-n {
    display: block;
    font: 700 14px/1 var(--font-display);
    color: var(--gold);
    letter-spacing: 0.14em;
    margin-bottom: 18px;
  }
  .principle h3 { font-size: 19px; margin: 0 0 8px; }
  .principle p { color: var(--muted); font-size: 14.5px; margin: 0; }
  .principle-grid .principle:first-child { border-top: 2px solid var(--gold-deep, var(--gold)); }

  .cta-final {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    padding: clamp(34px, 5vw, 60px);
    background:
      radial-gradient(90% 140% at 100% 0%, rgba(212, 175, 55, 0.09), transparent 55%),
      var(--surface);
  }
  .cta-final h2 { font-size: clamp(24px, 3.4vw, 34px); margin: 14px 0 12px; max-width: 22ch; }
  .cta-final .lead { margin: 0; max-width: 52ch; }
  .cta-actions { display: flex; flex-direction: column; gap: 12px; flex-shrink: 0; }

  @media (max-width: 820px) {
    .cta-final { flex-direction: column; align-items: flex-start; }
    .cta-actions { flex-direction: row; flex-wrap: wrap; }
    .season-stats { gap: 28px; }
  }
</style>
